{
  "name": "desktop",
  "private": true,
  "version": "1.0.0",
  "author": "Verbo AI",
  "description": "Predictive inline typing assistant powered by Google Gemini AI across Windows OS.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "rebuild": "electron-rebuild -f -w ffi-napi,ref-napi,uiohook-napi",
    "release": "tsc && vite build && electron-builder --publish always"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.68",
    "@ai-sdk/google": "^3.0.60",
    "@ai-sdk/openai": "^3.0.52",
    "@google/genai": "^1.48.0",
    "ai": "^6.0.152",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.14.0",
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "@types/events": "^3.0.3",
    "@types/ffi-napi": "^4.0.10",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@types/ref-napi": "^3.0.12",
    "@types/ref-struct-di": "^1.1.12",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js"
}
